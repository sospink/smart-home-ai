# ── 时区 ──────────────────────────────────
TZ=Asia/Shanghai

# ── Code Server ───────────────────────────
# Web IDE 登录密码
CODE_SERVER_PASSWORD=change_me_password
# 终端 sudo 密码
CODE_SERVER_SUDO_PASSWORD=change_me_sudo

# ── JupyterLab ────────────────────────────
# 访问 Token（访问 http://<host>:8888?token=<JUPYTER_TOKEN>）
JUPYTER_TOKEN=change_me_token_123456

# ── 路径映射 ──────────────────────────────
# 映射到 Code Server 的工作区目录（默认为项目根目录）
WORKSPACE_PATH=../
# JupyterLab notebooks 存储目录
NOTEBOOKS_PATH=./notebooks
# Home Assistant 配置目录
HA_CONFIG_PATH=./ha-config
