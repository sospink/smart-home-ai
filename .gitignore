# ═══════════════════════════════════════════
#  Smart Home AI Platform — .gitignore
# ═══════════════════════════════════════════

# ── OS ──
.DS_Store
Thumbs.db

# ── Logs ──
*.log
.backend.log
.frontend.log

# ── Editor / IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ═══════════════════════════════════════════
#  Python / FastAPI Backend
# ═══════════════════════════════════════════
venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# 环境变量（包含密钥，绝不提交）
smart-home-ai-backend/.env

# ═══════════════════════════════════════════
#  Next.js / React Frontend
# ═══════════════════════════════════════════
node_modules/
.next/
out/

# 环境变量
smart-home-ai-frontend/.env.local
smart-home-ai-frontend/.env*.local

# ═══════════════════════════════════════════
#  Misc
# ═══════════════════════════════════════════
*.sqlite3
*.db
