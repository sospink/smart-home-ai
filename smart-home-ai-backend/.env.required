# Backend 必要环境变量声明
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置 (MySQL)
# ============================================
MYSQL_ROOT_PASSWORD=           # MySQL root 密码
MYSQL_DATABASE=smart_home      # 数据库名称
MYSQL_USER=                    # 数据库用户名
MYSQL_PASSWORD=                # 数据库密码

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=                # Redis 访问密码

# ============================================
# OpenAI 配置
# ============================================
OPENAI_API_KEY=                # OpenAI API Key
OPENAI_BASE_URL=               # OpenAI Base URL (可选，用于代理)

# ============================================
# 应用安全配置
# ============================================
SECRET_KEY=                    # JWT/Session 密钥 (随机生成强密码)
ENVIRONMENT=production         # 运行环境: development | production

# ============================================
# 前端配置 (用于构建时的环境变量)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
